#!/usr/bin/env bash
# Moss CLI wrapper. Follows symlinks so it works when installed at ~/.local/bin/moss.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    TARGET="$(readlink "$SOURCE")"
    case "$TARGET" in
        /*) SOURCE="$TARGET" ;;
        *) SOURCE="$(dirname "$SOURCE")/$TARGET" ;;
    esac
done
DIR="$( cd "$( dirname "$SOURCE" )" && pwd )"
exec python3 "$DIR/compiler/moss.py" "$@"
